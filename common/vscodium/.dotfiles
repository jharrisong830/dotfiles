---
name: "settings.json"
location: "{HOME}/.vscode-oss/{NAME}" # no single correct path for multiple platforms
darwin:
  shouldLink: true
  location: "{HOME}/Library/Application Support/VSCodium/User/{NAME}"
linux:
  shouldLink: true
  location: "{HOME}/.config/VSCodium/User/{NAME}"
win32:
  shouldLink: true
  location: "{HOME}/AppData/Roaming/VSCodium/User/{NAME}"
